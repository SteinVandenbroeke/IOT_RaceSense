# Caddyfile
racesense.dcsteen.com {
    # Route all websocket and API traffic to the Python backend
    handle /ws/* {
        reverse_proxy backend:8000
    }

    handle /api/* {
        reverse_proxy backend:8000
    }

    # Route everything else to the SvelteKit frontend
    handle {
        reverse_proxy frontend:3000
    }
}